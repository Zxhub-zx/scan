-- ===== Minimize / Restore =====
local isMinimized = false

local function setMinimized(state)
    isMinimized = state
    if state then
        -- บันทึกตำแหน่ง mainFrame เพื่อ sync miniCircle
        local absPos = mainFrame.AbsolutePosition
        mainFrame.Visible = false
        miniCircle.Position = UDim2.new(0, absPos.X, 0, absPos.Y)
        miniCircle.Visible = true
        -- pulse animation บน miniCircle
        TweenService:Create(miniInner, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
            {BackgroundColor3 = Color3.fromRGB(0, 220, 255)}):Play()
    else
        -- restore: sync mainFrame position ไป miniCircle
        local absPos = miniCircle.AbsolutePosition
        mainFrame.Position = UDim2.new(0, absPos.X, 0, absPos.Y)
        miniCircle.Visible = false
        mainFrame.Visible = true
        TweenService:Create(mainFrame, TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
            {Size = UDim2.new(0, guiW, 0, guiH)}):Play()
    end
end

minBtn.MouseButton1Click:Connect(function()
