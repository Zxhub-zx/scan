-- ===== สร้าง Row =====
local rowCount = 0
local allData = {}

local function createRow(category, name, value, order)
    rowCount = rowCount + 1
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 36)
    row.BackgroundColor3 = rowCount % 2 == 0
        and Color3.fromRGB(18, 18, 30)
        or  Color3.fromRGB(24, 24, 40)
    row.BorderSizePixel = 0
    row.LayoutOrder = order or rowCount
    row.Parent = scrollFrame
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)

    local badge = Instance.new("TextLabel")
    badge.Size = UDim2.new(0, 72, 0, 20)
    badge.Position = UDim2.new(0, 4, 0.5, -10)
    badge.BackgroundColor3 = badgeColors[category] or Color3.fromRGB(60, 60, 100)
    badge.Text = category
    badge.TextColor3 = Color3.fromRGB(220, 240, 255)
    badge.TextSize = 9
    badge.Font = Enum.Font.GothamBold
    badge.TextTruncate = Enum.TextTruncate.AtEnd
    badge.Parent = row
    Instance.new("UICorner", badge).CornerRadius = UDim.new(0, 4)

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(0, 130, 1, 0)
    nameLabel.Position = UDim2.new(0, 80, 0, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = name
    nameLabel.TextColor3 = Color3.fromRGB(200, 220, 255)
    nameLabel.TextSize = 11
    nameLabel.Font = Enum.Font.Gotham
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
    nameLabel.Parent = row

    local valLabel = Instance.new("TextLabel")
    valLabel.Size = UDim2.new(0, 110, 1, 0)
    valLabel.Position = UDim2.new(0, 214, 0, 0)
    valLabel.BackgroundTransparency = 1
    valLabel.Text = tostring(value)
    valLabel.TextColor3 = Color3.fromRGB(0, 220, 180)
    valLabel.TextSize = 11
    valLabel.Font = Enum.Font.GothamBold
    valLabel.TextXAlignment = Enum.TextXAlignment.Left
    valLabel.TextTruncate = Enum.TextTruncate.AtEnd
    valLabel.Parent = row

    -- Copy Button (ใช้ pcall ครอบ setclipboard เผื่อรันใน Studio)
    local copyBtn = Instance.new("TextButton")
    copyBtn.Size = UDim2.new(0, 44, 0, 22)
    copyBtn.Position = UDim2.new(1, -50, 0.5, -11)
    copyBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 90)
    copyBtn.Text = "Copy"
    copyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    copyBtn.TextSize = 10
    copyBtn.Font = Enum.Font.GothamBold
    copyBtn.BorderSizePixel = 0
    copyBtn.Parent = row
    Instance.new("UICorner", copyBtn).CornerRadius = UDim.new(0, 5)

    copyBtn.MouseButton1Click:Connect(function()
        local text = "[" .. category .. "] " .. name .. ": " .. tostring(value)
        pcall(function() setclipboard(text) end) -- ไม่ crash ใน Studio
        copyBtn.Text = "✓"
        copyBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        task.delay(1.5, function()
            if copyBtn and copyBtn.Parent then
                copyBtn.Text = "Copy"
                copyBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 90)
            end
        end)
    end)

    table.insert(allData, {category = category, name = name, value = value}
