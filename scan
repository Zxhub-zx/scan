        local text = "[" .. category .. "] " .. name .. ": " .. tostring(value)
        pcall(function() setclipboard(text) end)
        copyBtn.Text = "✓"
        copyBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        task.delay(1.5, function()
            if copyBtn and copyBtn.Parent then
                copyBtn.Text = "Copy"
                copyBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 90)
            end
        end)
    end)

    table.insert(allData, {category = category, name = name, value = value})
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 12)
end

-- ===== Helpers =====
local function countDesc(instance, className)
    local ok, result = pcall(function()
        local n = 0
        for _, v in ipairs(instance:GetDescendants()) do
            if v:IsA(className) then n = n + 1 end
        end
        return n
    end)
    return ok and result or 0
end

local function getStat(key)
    local ok, val = pcall(function() return Stats[key] end)
    if ok and val ~= nil then
        return type(val) == "number" and math.floor(val * 100) / 100 or val
    end
    return "N/A"
end

