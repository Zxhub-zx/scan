-- ===== Toggle & Scan =====
local isOn = false
local scanning = false

local function animateToggle(on)
    local targetPos = on and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)
    local bgColor   = on and Color3.fromRGB(0, 200, 255) or Color3.fromRGB(60, 60, 80)
    local knobColor = on and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 200)
    TweenService:Create(toggleKnob, TweenInfo.new(0.2), {Position = targetPos, BackgroundColor3 = knobColor}):Play()
    TweenService:Create(toggleBg,   TweenInfo.new(0.2), {BackgroundColor3 = bgColor}):Play()
end

local function clearResults()
    for _, v in ipairs(scrollFrame:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end
    rowCount = 0
    allData = {}
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
end

local function runScan()
    if scanning then return end
    scanning = true
    clearResults()
    progressFill.Size = UDim2.new(0, 0, 1, 0)
    progressLabel.Text = "0%"

    local total = #scanTasks
    for i, fn in ipairs(scanTasks) do
        local ok, err = pcall(fn)
        if not ok then
            createRow("ERROR", "Task " .. i, tostring(err):sub(1, 50))
        end
        local pct = math.floor((i / total) * 100)
        TweenService:Create(progressFill, TweenInfo.new(0.15), {
            Size = UDim2.new(pct / 100, 0, 1, 0)
        }):Play()
        progressLabel.Text = pct .. "%"
        task.wait(0.2)
    end

    progressLabel.Text = "100%"
    statusLabel.Text = "✓ สแกนเสร็จ — พบ " .. #allData .. " รายการ"
    scanning = false
end

toggleButton.MouseButton1Click:Connect(function()
    isOn = not isOn
    animateToggle(isOn)
    if isOn then
        task.spawn(runScan)
    else
        scanning = false
        statusLabel.Text = "ปิดการสแกน"
        progressFill.Size = UDim2.new(0, 0, 1, 0)
        progressLabel.Text = "0%"
        clearResults()
    end
end)