	copyBtn.TextSize = 10
	copyBtn.Font = Enum.Font.GothamBold
	copyBtn.BorderSizePixel = 0
	copyBtn.Parent = row

	local copyCorner = Instance.new("UICorner")
	copyCorner.CornerRadius = UDim.new(0, 5)
	copyCorner.Parent = copyBtn

	copyBtn.MouseButton1Click:Connect(function()
		local textToCopy = "[" .. category .. "] " .. name .. ": " .. tostring(value)
		setclipboard(textToCopy)
		copyBtn.Text = "✓"
		copyBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 120)
		task.delay(1.5, function()
			copyBtn.Text = "Copy"
			copyBtn.BackgroundColor3 = Color3.fromRGB(0, 160, 100)
		end)
	end)

	table.insert(allData, {category = category, name = name, value = value})

	-- อัปเดต canvas
	scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 12)

	return row
end

-- ===== ฟังก์ชันนับ descendants =====
local function countDescendants(instance, className)
	local count = 0
	for _, v in pairs(instance:GetDescendants()) do
		if v:IsA(className) then count = count + 1 end
	end
	return count
end

