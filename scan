-- ===== Toggle & Scan Logic =====
local isOn = false
local scanning = false

local function animateToggle(on)
	local targetX = on and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)
	local targetColor = on and Color3.fromRGB(0, 200, 255) or Color3.fromRGB(60, 60, 80)
	local knobColor = on and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 200)
	TweenService:Create(toggleKnob, TweenInfo.new(0.2), {Position = targetX, BackgroundColor3 = knobColor}):Play()
	TweenService:Create(toggleBg, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
end

local function clearResults()
	for _, v in pairs(scrollFrame:GetChildren()) do
		if v:IsA("Frame") then v:Destroy() end
	end
	rowCount = 0
	allData = {}
	scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
end

local function runScan()
	if scanning then return end
	scanning = true
	clearResults()
	progressFill.Size = UDim2.new(0, 0, 1, 0)
	progressLabel.Text = "0%"

	local total = #scanTasks
	for i, task_ in ipairs(scanTasks) do
		task_()
		local pct = math.floor((i / total) * 100)
		local tween = TweenService:Create(progressFill, TweenInfo.new(0.15), {
			Size = UDim2.new(pct / 100, 0, 1, 0)
		})
		tween:Play()
		progressLabel.Text = pct .. "%"
		task.wait(0.25)
	end

	progressLabel.Text = "100%"
	statusLabel.Text = "✓ สแกนเสร็จสิ้น — พบข้อมูลทั้งหมด " .. #allData .. " รายการ"
	scanning = false
end

toggleButton.MouseButton1Click:Connect(function()
	isOn = not isOn
	animateToggle(isOn)
	if isOn then
		task.spawn(runScan)
	else
		statusLabel.Text = "ปิดการสแกน"
		progressFill.Size = UDim2.new(0, 0, 1, 0)
		progressLabel.Text = "0%"
		clearResults()
	end
end)
